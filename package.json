  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/amirkamary7-eng/amir-btc-assistant/issues"
  },
  "homepage": "https://github.com/amirkamary7-eng/amir-btc-assistant#readme",
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0"
  }
}
