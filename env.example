# Copy to .env and fill in values. Never commit secrets.

# PostgreSQL (required for user bootstrap, watchlist, language persistence)
DATABASE_URL=postgresql://user:password@localhost:5432/amir_btc

# Redis (optional — in-memory fallback used when unset)
REDIS_URL=redis://localhost:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=831704732
WEBAPP_URL=https://amir-btc-assistant.vercel.app
TELEGRAM_WEBHOOK_URL=https://amir-btc-assistant.onrender.com/telegram
REQUIRED_CHANNEL=amir_btc_2024

# Cache TTL for verified channel membership (seconds)
JOIN_CACHE_TTL=1800

# Max coins per user watchlist
MAX_WATCHLIST=7

# Server
PORT=8000

# Cloudflare Worker proxy target
BACKEND_URL=
