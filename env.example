# Copy to .env and fill in values. Never commit secrets.

# ============================================================================
# Cloudflare Worker (primary runtime)
# ============================================================================
DATABASE_URL=postgresql://user:password@host:5432/dbname?pgbouncer=true
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=
WEBAPP_URL=https://amir-btc-assistant-pages.pages.dev
REQUIRED_CHANNEL=amir_btc_2024
APP_ENV=development

# Webhook secret — set via BotFather & wrangler secret (Task 2.11)
TELEGRAM_WEBHOOK_SECRET=

# Cache TTLs (seconds)
JOIN_CACHE_TTL=1800
NEWS_CACHE_TTL=300
CALENDAR_CACHE_TTL=600
CHART_EXCHANGE_CACHE_TTL=86400
SESSION_TTL=120

# Alerts
ALERTS_CRON_ENABLED=false
ALERTS_CRON_SHARED_SECRET=

# AI Assistant (keys via wrangler secret — never hardcode)
GEMINI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
AI_DAILY_MESSAGE_LIMIT=50
AI_DAILY_IMAGE_LIMIT=3
AI_COOLDOWN_SECONDS=4

# Referral
REFERRAL_TOKENS_PER_INVITE=3

# ============================================================================
# FastAPI (legacy — only while dual-runtime is active)
# ============================================================================
# REDIS_URL=redis://localhost:6379/0
MAX_WATCHLIST=7
ALERTS_POLLING_MODE=loop
PORT=8000

# Webhook URL (FastAPI sets this via bot.setWebhook)
TELEGRAM_WEBHOOK_URL=

# ============================================================================
# Build-time (scripts/prepare-pages.mjs reads this)
# ============================================================================
WORKER_API_URL=https://amir-btc-assistant-api-production.<account>.workers.dev