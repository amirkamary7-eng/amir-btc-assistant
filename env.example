# Copy to .env and fill in values. Never commit secrets.

# ============================================================================
# Cloudflare Worker Shell / Pages Migration
# این envها برای shell مرحله‌ای مهاجرت طبق docs استفاده می‌شوند.
# ============================================================================

# PostgreSQL (required for user bootstrap, watchlist, language persistence)
DATABASE_URL=postgresql://postgres.qywuklmhjqovmqlyklea:[Pssword]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Redis (optional — in-memory fallback used when unset)
REDIS_URL=redis://localhost:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=831704732
WEBAPP_URL=https://amir-btc-assistant.vercel.app
TELEGRAM_WEBHOOK_URL=
REQUIRED_CHANNEL=amir_btc_2024

# Cache TTL for verified channel membership (seconds)
JOIN_CACHE_TTL=1800

# Max coins per user watchlist
MAX_WATCHLIST=7

# Cache TTLs (seconds)
MARKET_CACHE_TTL=60
NEWS_CACHE_TTL=300
CALENDAR_CACHE_TTL=600
CHART_EXCHANGE_CACHE_TTL=86400
ANALYSIS_CACHE_TTL=30
SESSION_TTL=120

# Alerts execution mode
# - loop: legacy FastAPI background loop
# - scheduled: execution triggered by Cloudflare Worker cron
ALERTS_POLLING_MODE=loop
ALERTS_CRON_SHARED_SECRET=

# AI Assistant (keys from env only — never hardcode)
GEMINI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
AI_DAILY_MESSAGE_LIMIT=50
AI_DAILY_IMAGE_LIMIT=3
AI_COOLDOWN_SECONDS=4

# Referral tokens
REFERRAL_TOKENS_PER_INVITE=3

# Server
PORT=8000

# Cloudflare Worker proxy target
BACKEND_URL=

# Worker environment label
APP_ENV=development
